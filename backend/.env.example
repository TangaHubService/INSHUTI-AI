# Postgres connection string (production / CI). For local dev without a
# Postgres instance, set this to a sqlite file path instead — resolved
# relative to prisma/, so this creates prisma/dev.db:
# DATABASE_URL="file:./dev.db"
# and use the `dev:db:*` npm scripts, which target prisma/schema.sqlite.prisma.
DATABASE_URL="postgresql://user:password@localhost:5432/inshuti?schema=public"

# Long random secrets — generate with `openssl rand -hex 32`. Never reuse
# between environments.
JWT_SECRET=""
SESSION_COOKIE_SECRET=""

OPENAI_API_KEY=""

# Frontend origin, used for CORS.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

PORT=4000
NODE_ENV="development"

# Super admin seeded by `npm run db:migrate:deploy && npx tsx prisma/seed.ts`
# (or `npm run dev:db:seed` locally). Email defaults to
# sibomanadamascene1999@gmail.com if SEED_SUPER_ADMIN_EMAIL is unset — the
# password has NO default and must be set here for non-interactive/production
# seeding; local interactive runs fall back to a masked terminal prompt.
SEED_SUPER_ADMIN_EMAIL="sibomanadamascene1999@gmail.com"
SEED_SUPER_ADMIN_PASSWORD=""
SEED_SUPER_ADMIN_NAME="Super Admin"

# Demo accounts (teen/parent/nurse/gov@example.com) seeded locally with this
# password by default if unset ("test1234"). In production there is no
# default — set this explicitly if you actually want those demo accounts
# on a production database; otherwise leave it unset and seeding skips them.
SEED_DEMO_USERS_PASSWORD=""
