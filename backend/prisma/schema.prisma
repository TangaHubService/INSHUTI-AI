// Primary schema — PostgreSQL, used for CI/production.
// For local dev without a Postgres instance, use prisma/schema.sqlite.prisma
// (see package.json "dev:db:*" scripts). Both schemas generate the client to
// the same output path, so application code always imports from one place.
//
// SQLite supports neither native `enum` nor `Json` columns, and this schema
// must generate identically on both providers (see scripts/sync-sqlite-schema.mjs).
// So: "enum" fields below are `String`, constrained by the TS union types and
// Zod schemas in src/lib/constants.ts, not by the database. `tags` (Article)
// and `sourcesUsed` (Message) are `String` columns holding JSON-encoded
// arrays, read/written via src/lib/jsonColumn.ts — never assign them raw.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Topic {
  id         String    @id @default(cuid())
  slug       String    @unique
  nameEn     String
  nameRw     String
  nameFr     String @default("")
  nameSw     String @default("")
  icon       String
  colorToken String
  articles   Article[]
  messages   Message[]
}

model Article {
  id         String    @id @default(cuid())
  topicId    String
  topic      Topic     @relation(fields: [topicId], references: [id])
  titleEn    String
  titleRw    String
  titleFr    String @default("")
  titleSw    String @default("")
  bodyEn     String
  bodyRw     String
  bodyFr     String @default("")
  bodySw     String @default("")
  externalUrl String?
  tags       String    @default("[]")
  status     String    @default("NEEDS_REVIEW")
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([topicId, titleEn])
  @@index([topicId])
}

model Conversation {
  id            String         @id @default(cuid())
  sessionId     String
  language      String
  userId        String?
  user          User?          @relation(fields: [userId], references: [id])
  consultation  Consultation?
  createdAt     DateTime       @default(now())
  messages      Message[]

  @@index([sessionId])
  @@index([userId])
}

model Message {
  id             String         @id @default(cuid())
  conversationId String
  conversation   Conversation   @relation(fields: [conversationId], references: [id])
  consultationId String?
  role           String
  content        String
  topicId        String?
  topic          Topic?         @relation(fields: [topicId], references: [id])
  sourcesUsed    String         @default("[]")
  confidence     Float?
  flaggedItem    FlaggedItem?
  createdAt      DateTime       @default(now())

  @@index([conversationId])
  @@index([consultationId])
}

model FlaggedItem {
  id            String    @id @default(cuid())
  messageId     String    @unique
  message       Message   @relation(fields: [messageId], references: [id])
  reason        String
  status        String    @default("FLAGGED")
  reviewerNotes String?
  resolvedBy    String?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model CrisisResource {
  id      String @id @default(cuid())
  name    String
  contact String
  region  String
  order   Int
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  phone             String?
  passwordHash      String
  name              String
  role              String
  preferredLanguage String   @default("EN")
  loginAttempts     Int      @default(0)
  lockedUntil       DateTime?
  lastActivityAt    DateTime @default(now())
  resetTokenHash    String?
  resetTokenExpiresAt DateTime?
  notificationPrefs String   @default("{}")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())

  healthcareProfessional HealthcareProfessional?
  governmentUser        GovernmentUser?
  consultations         Consultation[]
  conversations         Conversation[]
  appointments          Appointment[]
  notifications         Notification[]

  @@index([email])
}

model HealthcareProfessional {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])
  professionalType String
  specialization   String?
  availability     String?
  approvalStatus   String    @default("PENDING")
  approvedBy       String?
  approvedAt       DateTime?
  consultations    Consultation[]
  appointments     Appointment[]

  @@index([professionalType])
}

model GovernmentUser {
  id         String @id @default(cuid())
  userId     String @unique
  user       User   @relation(fields: [userId], references: [id])
  level      String
  regionName String
}

model Consultation {
  id                 String    @id @default(cuid())
  conversationId     String    @unique
  conversation       Conversation @relation(fields: [conversationId], references: [id])
  userId             String
  user               User      @relation(fields: [userId], references: [id])
  professionalId     String?
  professional       HealthcareProfessional? @relation(fields: [professionalId], references: [id])
  status             String    @default("PENDING")
  priority           Int       @default(0)
  assignedAt         DateTime?
  resolvedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([professionalId])
  @@index([status])
}

model Appointment {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  professionalId String
  professional   HealthcareProfessional @relation(fields: [professionalId], references: [id])
  requestedTime  DateTime
  status         String    @default("REQUESTED")
  notes          String?
  outcome        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([professionalId])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
}

model HealthFacility {
  id        String   @id @default(cuid())
  name      String
  type      String
  latitude  Float
  longitude Float
  district  String
  sector    String
  services  String   @default("[]")
  contact   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([district])
  @@index([type])
}

model AppSettings {
  id                      String  @id @default("singleton")
  aiProvider              String
  aiModel                 String
  responseStyleNote       String
  restrictToKnowledgeBase Boolean
  autoFlagCrisisLanguage  Boolean
  autoDetectLanguage      Boolean
  sessionTimeoutMinutes   Int     @default(60)
  maxLoginAttempts        Int     @default(5)
  lockoutDurationMinutes  Int     @default(15)
}
