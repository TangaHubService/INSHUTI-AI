// Primary schema — PostgreSQL, used for CI/production.
// For local dev without a Postgres instance, use prisma/schema.sqlite.prisma
// (see package.json "dev:db:*" scripts). Both schemas generate the client to
// the same output path, so application code always imports from one place.
//
// SQLite supports neither native `enum` nor `Json` columns, and this schema
// must generate identically on both providers (see scripts/sync-sqlite-schema.mjs).
// So: "enum" fields below are `String`, constrained by the TS union types and
// Zod schemas in src/lib/constants.ts, not by the database. `tags` (Article)
// and `sourcesUsed` (Message) are `String` columns holding JSON-encoded
// arrays, read/written via src/lib/jsonColumn.ts — never assign them raw.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Topic {
  id         String    @id @default(cuid())
  slug       String    @unique
  nameEn     String
  nameRw     String
  icon       String
  colorToken String
  articles   Article[]
  messages   Message[]
}

model Article {
  id         String    @id @default(cuid())
  topicId    String
  topic      Topic     @relation(fields: [topicId], references: [id])
  titleEn    String
  titleRw    String
  bodyEn     String
  bodyRw     String
  tags       String    @default("[]")
  status     String    @default("NEEDS_REVIEW")
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([topicId, titleEn])
  @@index([topicId])
}

model Conversation {
  id        String    @id @default(cuid())
  sessionId String
  language  String
  createdAt DateTime  @default(now())
  messages  Message[]

  @@index([sessionId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           String
  content        String
  topicId        String?
  topic          Topic?       @relation(fields: [topicId], references: [id])
  sourcesUsed    String       @default("[]")
  confidence     Float?
  flaggedItem    FlaggedItem?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

model FlaggedItem {
  id            String    @id @default(cuid())
  messageId     String    @unique
  message       Message   @relation(fields: [messageId], references: [id])
  reason        String
  status        String    @default("FLAGGED")
  reviewerNotes String?
  resolvedBy    String?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String
  createdAt    DateTime @default(now())
}

model CrisisResource {
  id      String @id @default(cuid())
  name    String
  contact String
  region  String
  order   Int
}

model AppSettings {
  id                      String  @id @default("singleton")
  aiProvider              String
  aiModel                 String
  responseStyleNote       String
  restrictToKnowledgeBase Boolean
  autoFlagCrisisLanguage  Boolean
  autoDetectLanguage      Boolean
}
